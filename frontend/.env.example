# ─────────────────────────────────────────────────────────────────────────
# TBC AI Tools — Frontend environment variables
# Copy this file to `frontend/.env` and fill in real values.
# NEVER commit the real `.env` (it is git-ignored).
#
# NOTE: Create React App only exposes vars prefixed with REACT_APP_ to the
# browser. Do NOT put secrets here — anything in this file ships to clients.
# ─────────────────────────────────────────────────────────────────────────

# Base URL of the backend API (no trailing slash). The app calls `${URL}/api`.
# Local dev:
REACT_APP_BACKEND_URL=http://localhost:8000
# Production example:
# REACT_APP_BACKEND_URL=https://www.tbctools.org
