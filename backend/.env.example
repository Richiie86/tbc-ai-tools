# ─────────────────────────────────────────────────────────────────────────
# TBC AI Tools — Backend environment variables
# Copy this file to `backend/.env` and fill in real values.
# NEVER commit the real `.env` (it is git-ignored).
# ─────────────────────────────────────────────────────────────────────────

# ── Database (required) ─────────────────────────────────────────────────
# MongoDB connection string and database name.
MONGO_URL=mongodb://localhost:27017
DB_NAME=tbc_ai_tools

# ── Auth (required) ─────────────────────────────────────────────────────
# Secret used to sign JWT session tokens. Generate a strong random value:
#   openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string

# Bootstrap operator account, seeded on first startup. Change the password
# immediately after first login.
OPERATOR_EMAIL=operator@example.com
OPERATOR_PASSWORD=change-me-strong-password
# Set to "true" once to force-reset the operator password to OPERATOR_PASSWORD
# on next startup, then remove it.
# RESET_OPERATOR_PASSWORD=false
# Default repo pre-filled in the Operator Console (org/repo).
# OPERATOR_DEFAULT_REPO=Richiie86/tbc-ai-tools

# ── CORS (optional) ─────────────────────────────────────────────────────
# Comma-separated allow-list of origins, or "*" for public (no credentials).
# Leave unset to use the built-in production regex (tbctools.org + previews).
# CORS_ORIGINS=https://www.tbctools.org,https://tbctools.org

# ── LLM providers ───────────────────────────────────────────────────────
# At least one provider key is needed for AI features (chat, code review,
# auto-fix). Set whichever provider(s) you use — the app auto-detects them.
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
# Override the cross-AI second-opinion reviewer model (must be a valid id).
# SECOND_OPINION_MODEL=claude-sonnet-4-5-20250929

# ── Integrations (optional) ─────────────────────────────────────────────
# GitHub token for repo review / deploy (repo scope).
GITHUB_TOKEN=
# Vercel deploy token + project URL.
VERCEL_TOKEN=
VERCEL_URL=
# Stripe (payments / credits).
STRIPE_API_KEY=
# Resend (transactional email).
RESEND_API_KEY=
SENDER_EMAIL=no-reply@example.com
# Upstash Redis (rate limiting / caching). Either REDIS_URL or the REST pair.
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── URLs (optional) ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
PUBLIC_APP_URL=http://localhost:3000
PUBLIC_FRONTEND_URL=http://localhost:3000

# ── Backups / proxies (optional) ────────────────────────────────────────
# BACKUP_SNAPSHOT_DIR=/var/data/snapshots
# BACKUP_SNAPSHOT_RETENTION_DAYS=14
# TRUSTED_PROXIES=127.0.0.1

# ── Test-only (optional) ────────────────────────────────────────────────
# Credentials the integration test-suite logs in with. Tests SKIP when unset.
# TEST_OPERATOR_EMAIL=operator@example.com
# TEST_OPERATOR_PASSWORD=
# TEST_PREVIEW_USER_EMAIL=preview-user@example.com
# TEST_USER_PASSWORD=
